{
    "name": "ultrapackadm/deckwp-connect",
    "description": "DeckWP Connect — WordPress connector plugin. Pairs WP sites with the DeckWP dashboard for bulk management, updates, backup, and scan.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://deckwp.com",
    "support": {
        "issues": "https://github.com/ultrapackadm/deckwp-connect/issues",
        "source": "https://github.com/ultrapackadm/deckwp-connect"
    },
    "require": {
        "php": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "DeckWP\\Connect\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeckWP\\Connect\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
